---
import BaseHead from "../components/BaseHead.astro";
import "../styles/global.css";
import { translations } from "../i18n";

export function getStaticPaths() {
  return [
    { params: { lang: "en" } },
    { params: { lang: "es" } },
    { params: { lang: "ar" } },
    { params: { lang: "ja" } },
    { params: { lang: "zh" } },
    { params: { lang: "de" } },
    { params: { lang: "fr" } },
    { params: { lang: "sv" } },
    { params: { lang: "ca" } },
    { params: { lang: "ru" } },
  ];
}

const { lang } = Astro.params;
const t = translations[lang as keyof typeof translations] || translations.en;
const isRTL = lang === 'ar';
---

<!doctype html>
<html lang={lang} dir={isRTL ? "rtl" : "ltr"}>
	<head>
		<BaseHead title={t.site_title} description={t.site_description} />
		<style>
			/* Local overrides for the Snellenberg vibe */
			.hero {
				height: 100vh;
				display: flex;
				flex-direction: column;
				justify-content: center;
			}
			.huge-title {
				font-size: clamp(3.5rem, 12vw, 10rem);
				line-height: 0.85;
				font-weight: 800;
				margin-bottom: 2.5rem;
				letter-spacing: -0.03em;
			}
			.section-label {
				font-size: 0.75rem;
				text-transform: uppercase;
				letter-spacing: 0.3em;
				color: var(--text-muted);
				margin-bottom: 1.5rem;
				display: block;
			}
			.work-list:hover .work-item:not(:hover) {
				opacity: 0.2;
				filter: grayscale(1);
			}
			.work-item {
				border-bottom: 1px solid rgba(0,0,0,0.1);
				padding: 4rem 0;
				transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
				cursor: pointer;
			}
			.work-item:hover {
				border-bottom-color: var(--primary);
			}
			.work-item .btn-primary {
				opacity: 0;
				transform: translateY(20px);
				transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
			}
			.work-item:hover .btn-primary {
				opacity: 1;
				transform: translateY(0);
			}
			.work-item h3 {
				transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
			}
			.work-item:hover h3 {
				transform: translateX(20px);
			}
			[dir="rtl"] .work-item:hover h3 {
				transform: translateX(-20px);
			}

			/* Smooth display for localized button */
			.hero .btn-primary, .hero .text-dark {
				transition: all 0.3s ease;
			}
			.hero .text-dark:hover {
				opacity: 0.7;
				transform: translateX(5px);
			}
		</style>
	</head>
	<body>
		<main data-scroll-container>
			<!-- Hero Section -->
			<section class="hero">
				<div class="container-wide">
					<div class="row">
						<div class="col-lg-10">
							<span class="section-label reveal">{t.role}</span>
							<h1 class="huge-title reveal">
								{t.hero_title}
							</h1>
							<div class="reveal d-flex gap-4 align-items-center">
								<a href="#contact" class="btn btn-primary btn-lg">{t.hero_btn}</a>
								{(lang === 'en' || lang === 'es') && (
									<a href={`/${lang}/blog`} class="text-dark text-decoration-none fw-bold ms-3">{t.blog} →</a>
								)}
							</div>
						</div>
					</div>
				</div>
			</section>

			<!-- About Section -->
			<section id="about" class="py-10">
				<div class="container-wide">
					<div class="row align-items-center">
						<div class="col-lg-6 mb-5 mb-lg-0">
							<div class="glass-panel p-5 reveal">
								<h2 class="m-0 display-4 fw-bold mb-3">{t.about_title}</h2>
								<p class="mb-4 fw-bold">{t.about_name}</p>
								<p class="lead mb-4">
									{t.about_p1}
								</p>
								<p class="text-muted">
									{t.about_p2}
								</p>
							</div>
						</div>
						<div class="col-lg-5 offset-lg-1">
							<div class="reveal">
								<h3 class="font-playfair display-4 italic mb-4" style="line-height: 1.4;">{t.about_quote}</h3>
							</div>
						</div>
					</div>
				</div>
			</section>

			<!-- Works Section -->
			<section id="works" class="py-10">
				<div class="container-wide">
					<div class="row">
						<div class="col-12">
							<span class="section-label reveal">{t.works_label}</span>
							<div class="work-list mt-5">
								<div class="work-item reveal">
									<div class="d-flex flex-column w-100">
										<div class="d-flex justify-content-between align-items-baseline mb-3">
											<h3 class="display-3 m-0 fw-bold">Esparta digital</h3>	
											<span class="text-muted">Full Stack / 2024</span>
										</div>
										<div>
											<a href="https://espartadigital.com" target="_blank" rel="noopener noreferrer" class="btn btn-primary">{t.works_visit}</a>
										</div>
									</div>
								</div>
								<div class="work-item reveal">
									<div class="d-flex flex-column w-100">
										<div class="d-flex justify-content-between align-items-baseline mb-3">
											<h3 class="display-3 m-0 fw-bold">VANTAG.es</h3>
											<span class="text-muted">Founder / 2024</span>
										</div>
										<div>
											<a href="https://vantage.es" target="_blank" rel="noopener noreferrer" class="btn btn-primary">{t.works_visit}</a>
										</div>
									</div>
								</div>
								<div class="work-item reveal">
									<div class="d-flex flex-column w-100">
										<div class="d-flex justify-content-between align-items-baseline mb-3">
											<h3 class="display-3 m-0 fw-bold">LEGALZONE.es</h3>
											<span class="text-muted">Founder / 2023</span>
										</div>
										<div>
											<a href="https://legalzone.es" target="_blank" rel="noopener noreferrer" class="btn btn-primary">{t.works_visit}</a>
										</div>
									</div>
								</div>
								<div class="work-item reveal">
									<div class="d-flex flex-column w-100">
										<div class="d-flex justify-content-between align-items-baseline mb-3">
											<h3 class="display-3 m-0 fw-bold">ELOLIVO.eu</h3>
											<span class="text-muted">{t.works_soon}</span>
										</div>
										<div>
											<a href="https://elolivo.eu" target="_blank" rel="noopener noreferrer" class="btn btn-primary">{t.works_visit}</a>
										</div>
									</div>
								</div>
							</div>
						</div>
					</div>
				</div>
			</section>

			<!-- Contact Section -->
			<section id="contact" class="vh-100 d-flex align-items-center">
				<div class="container-wide">
					<div class="row justify-content-center text-center">
						<div class="col-lg-10">
							<h2 class="huge-title reveal">{t.contact_title}</h2>
							<div class="reveal">
								<p class="lead mb-5">{t.contact_p}</p>
								<div class="d-flex justify-content-center">
									<a href="mailto:me@jmfernandez.dev" class="display-3 font-playfair text-decoration-none text-dark border-bottom border-dark pb-2">me@jmfernandez.dev</a>
								</div>
							</div>
						</div>
					</div>
				</div>
			</section>
		</main>

		<!-- The Signature Marquee -->
		<div class="marquee-container">
			<div class="marquee-content" id="main-marquee">
				Jose Manuel Fernández — Jose Manuel Fernández — Jose Manuel Fernández — Jose Manuel Fernández —
			</div>
		</div>

		<script>
			import { gsap } from "gsap";
			import { ScrollTrigger } from "gsap/ScrollTrigger";
			import Lenis from 'lenis';

			gsap.registerPlugin(ScrollTrigger);

			window.addEventListener('DOMContentLoaded', () => {
				// 0. Smooth Scroll (Lenis)
				const lenis = new Lenis({
					duration: 1.2,
					easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
					orientation: 'vertical',
					gestureOrientation: 'vertical',
					smoothWheel: true,
					wheelMultiplier: 1,
					smoothTouch: false,
					touchMultiplier: 2,
					infinite: false,
				});

				function raf(time: number) {
					lenis.raf(time);
					requestAnimationFrame(raf);
				}
				requestAnimationFrame(raf);

				// Connect Lenis to ScrollTrigger
				lenis.on('scroll', ScrollTrigger.update);
				gsap.ticker.add((time) => {
					lenis.raf(time * 1000);
				});
				gsap.ticker.lagSmoothing(0);

				// 1. Entry Animation (Instant)
				gsap.set('.reveal', { y: 60, opacity: 0 });

				gsap.to('.reveal', {
					y: 0,
					opacity: 1,
					duration: 1.2,
					stagger: 0.15,
					ease: "power4.out"
				});

				// 2. Marquee Animation
				const marquee = document.getElementById('main-marquee');
				let marqueeAnim: gsap.core.Tween | null = null;
				if (marquee) {
					marqueeAnim = gsap.to(marquee, {
						xPercent: -50,
						ease: "none",
						duration: 25,
						repeat: -1,
					});
				}

				gsap.to('.marquee-container', {
					scrollTrigger: {
						trigger: "body",
						start: "top top",
						end: "bottom bottom",
						scrub: 1,
					},
					y: -20,
					opacity: 0.5,
				});

				// 3. Reveal sections on scroll
				gsap.utils.toArray('section:not(.hero) .reveal').forEach((elem: any) => {
					gsap.to(elem, {
						scrollTrigger: {
							trigger: elem,
							start: "top 85%",
							toggleActions: "play none none none"
						},
						y: 0,
						opacity: 1,
						duration: 1.2,
						ease: "power3.out"
					});
				});

				// 4. Marquee speed up on scroll
				let scrollVelocity = 0;
				ScrollTrigger.create({
					onUpdate: (self) => {
						scrollVelocity = self.getVelocity() / 100;
						if (marqueeAnim) {
							gsap.to(marqueeAnim, {
								timeScale: Math.abs(scrollVelocity) + 1,
								duration: 0.5
							});
						}
					}
				});
			});
		</script>
	</body>
</html>
